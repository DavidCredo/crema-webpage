---
import Base from "../layouts/Base.astro";
import { useTranslations } from "../i18n/utils";
const t = useTranslations(Astro.url);
---

<Base title={t("support.title")} description={t("support.intro")}>
	<div class="max-w-2xl mx-auto px-6 py-16 md:py-24">
		<h1 class="font-display text-4xl text-espresso-900 mb-2">{t("support.heading")}</h1>
		<p class="text-espresso-400 mb-12">{t("support.intro")}</p>

		<div class="space-y-10 text-[15px]">
			<section class="bg-espresso-50 border border-espresso-100/60 rounded-2xl p-6 md:p-8">
				<h2 class="font-display text-xl text-espresso-800 mb-3">{t("support.contact.heading")}</h2>
				<p class="text-espresso-500 leading-relaxed mb-4">{t("support.contact.text")}</p>
				<a href="mailto:crema@credo.codes" class="inline-flex items-center gap-2 text-espresso-700 font-medium hover:text-espresso-500 transition-colors">
					<svg width="18" height="18" viewBox="0 0 18 18" fill="none">
						<rect x="2" y="4" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.4" />
						<path d="M2 6L9 10L16 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
					</svg>
					crema@credo.codes
				</a>
			</section>

			<section>
				<h2 class="font-display text-xl text-espresso-800 mb-6">{t("support.faq.heading")}</h2>
				<div class="space-y-6">
					<div>
						<h3 class="font-medium text-espresso-800 mb-1">{t("support.faq.data_storage.q")}</h3>
						<p class="text-espresso-500 leading-relaxed">{t("support.faq.data_storage.a")}</p>
					</div>
					<div>
						<h3 class="font-medium text-espresso-800 mb-1">{t("support.faq.export.q")}</h3>
						<p class="text-espresso-500 leading-relaxed">{t("support.faq.export.a")}</p>
					</div>
					<div>
						<h3 class="font-medium text-espresso-800 mb-1">{t("support.faq.delete.q")}</h3>
						<p class="text-espresso-500 leading-relaxed">{t("support.faq.delete.a")}</p>
					</div>
					<div>
						<h3 class="font-medium text-espresso-800 mb-1">{t("support.faq.free.q")}</h3>
						<p class="text-espresso-500 leading-relaxed">{t("support.faq.free.a")}</p>
					</div>
					<div>
						<h3 class="font-medium text-espresso-800 mb-1">{t("support.faq.bug.q")}</h3>
						<p class="text-espresso-500 leading-relaxed">
							{t("support.faq.bug.a_prefix")}<a href="mailto:crema@credo.codes" class="underline underline-offset-2 text-espresso-700 hover:text-espresso-500 transition-colors">crema@credo.codes</a>{t("support.faq.bug.a_suffix")}
						</p>
					</div>
				</div>
			</section>
		</div>
	</div>
</Base>